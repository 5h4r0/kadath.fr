NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# URLs — local : voir docs/local-dev-hosts.md pour la config /etc/hosts
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MANAGE_URL=http://localhost:3001
FORCE_ADMIN_HOST=false
